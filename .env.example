# Vercel 대시보드 → Project → Settings → Environment Variables 에 등록할 값들.
# 이 파일은 샘플이며 실제 값은 Vercel 대시보드에만 입력합니다.
# (로컬 vercel CLI 사용 시에만 `vercel env pull` 로 내려받아 참고)

# 프록시 공유 토큰 — 로컬 Flask 앱의 .env 에 있는 SADO_PROXY_TOKEN 과 반드시 동일
# 생성 예: python -c "import secrets; print(secrets.token_urlsafe(32))"
SADO_PROXY_TOKEN=

# CORS 허용 Origin (쉼표로 여러 개). 서버-서버 호출에는 필수 아니지만 브라우저 직접호출 차단용.
SADO_ALLOWED_ORIGIN=http://127.0.0.1:5000,http://localhost:5000

# 분당 호출 한도 (인스턴스 기준, 인스턴스가 여러 개면 per-instance 적용됨)
SADO_RATE_LIMIT_PER_MIN=30

# 라쿠텐 (https://webservice.rakuten.co.jp/)
RAKUTEN_APP_ID=

# 네이버 쇼핑 검색 (https://developers.naver.com/apps/)
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# eBay Browse API (다음주 연동 예정 — https://developer.ebay.com/)
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENV=production
